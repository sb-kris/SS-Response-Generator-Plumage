# Plumage — environment variables
# Copy this file to `.env.local` for local dev, or configure these in Vercel
# for production.
#
# Plumage no longer ships with password-based auth — the app is gated only
# by the SurveySparrow + LLM API keys that the user enters on the Setup
# page (kept in browser memory, never persisted). If you want a network-
# level gate, put the deployment behind Vercel's password protection or
# your own SSO at the host level.

# OPTIONAL: Soft monthly cost cap in USD. Surfaces a warning when projected
# costs approach this. Does NOT block generation — purely informational.
# Default: 100
MONTHLY_COST_CAP_USD="100"
