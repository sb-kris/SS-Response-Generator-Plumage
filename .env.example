# Plumage — environment variables
# Copy this file to `.env.local` for local dev, or configure these in Vercel for production.

# REQUIRED: Password for accessing the app. Anyone with this password can use it.
# Use something strong; rotate when team members leave.
APP_PASSWORD="change-me-in-production"

# REQUIRED: Secret used to sign the auth cookie. Use 32+ random bytes.
# Generate with:  openssl rand -hex 32
AUTH_SECRET="generate-a-32-byte-hex-string-here"

# OPTIONAL: Soft monthly cost cap in USD. Used to surface a warning when projected costs approach this.
# Does not block generation — purely informational. Default: 100
MONTHLY_COST_CAP_USD="100"
